{
  "name": "scholar-sidekick-mcp",
  "version": "0.8.5",
  "mcpName": "io.github.mlava/scholar-sidekick-mcp",
  "description": "MCP server that catches AI-fabricated citations: verifies a claimed title against the real record at its DOI or PMID (the Topaz et al. Lancet 2026 pattern), audits whole bibliographies, and checks retraction and open-access status — plus citation formatting in 10,000+ CSL styles and export to BibTeX, RIS, and EndNote.",
  "license": "MIT",
  "author": "Scholar Sidekick",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mlava/scholar-sidekick-mcp.git"
  },
  "homepage": "https://scholar-sidekick.com/mcp",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "citations",
    "bibliography",
    "academic",
    "scholar",
    "doi",
    "pmid",
    "pmcid",
    "isbn",
    "arxiv",
    "issn",
    "ads-bibcode",
    "who-iris",
    "bibtex",
    "ris",
    "csl",
    "endnote",
    "zotero",
    "crossref",
    "reference-manager",
    "retraction",
    "retraction-watch",
    "open-access",
    "unpaywall",
    "claude"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "scholar-sidekick-mcp": "dist/mcp-server.mjs"
  },
  "files": [
    "SECURITY.md",
    "dist/mcp-server.mjs",
    "tools.json"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "sync:surface": "node scripts/sync-surface.mjs",
    "pack": "npm run build && node scripts/pack.mjs",
    "test": "vitest run",
    "test:ci": "vitest run --allowOnly=false",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@vitest/coverage-v8": "^2.1.9",
    "esbuild": "^0.25.8",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.9"
  }
}
